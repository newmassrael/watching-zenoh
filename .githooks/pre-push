#!/usr/bin/env bash
# pre-push hook — CI-equivalent local gate before publishing to remote.
#
# R64 retrospect: prior to this hook the only push-time gate was
# `mnemosyne-cli validate-workspace`. CI yaml regressions (R64.1's
# `--package` flag that cargo install does not accept) shipped to
# remote and were observed only after the GitHub Actions runner
# rejected them. The fix is to mirror CI's full gate-set locally
# so push-time catches what land-then-CI used to.
#
# Delegates to `scripts/run-ci.sh` so CI and pre-push share one
# source of truth for the lane definitions (Layer 0 actionlint /
# A mnemosyne / B verify-codegen / C1 cargo test / C2 clippy /
# D deploy yaml).
#
# Time cost (warm cache): ~50s typical; up to ~5min on cold
# compile. The hook can be bypassed via `git push --no-verify`
# for genuinely urgent hotfixes — that escape hatch is the
# standard git contract; do not use it to dodge real failures.
#
# Install via `git config core.hooksPath .githooks` (one-time per clone).
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if [[ ! -x scripts/run-ci.sh ]]; then
    echo "pre-push: scripts/run-ci.sh missing or not executable" >&2
    echo "  chmod +x scripts/run-ci.sh" >&2
    exit 1
fi

echo "pre-push: running CI-equivalent gate (scripts/run-ci.sh) ..."
if ! scripts/run-ci.sh; then
    echo "" >&2
    echo "pre-push: CI-equivalent gate failed — fix locally before push." >&2
    echo "          Bypass with `git push --no-verify` only for genuine hotfixes." >&2
    exit 1
fi

exit 0
